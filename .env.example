# ===========================================
# GRIT — Environment Variables Example
# ===========================================
# Copy to .env and fill in real values. Never commit .env.
# ===========================================

# ===========================================
# DATABASE
# ===========================================
DATABASE_URL=postgresql://user:password@host:5432/dbname
DIRECT_URL=postgresql://user:password@host:5432/dbname
DB_MAX_CONNECTIONS=10

# Isolated proof database. Never point this at DATABASE_URL or DIRECT_URL.
# Keep in .env.staging.local (gitignored), not the normal production environment.
STAGING_DATABASE_URL=
STAGING_ENVIRONMENT_ID=grit-staging-replace-with-unique-id
ALLOW_STAGING_WRITES=0
ALLOW_RANKING_RECONCILIATION=0

# ===========================================
# SUPABASE
# ===========================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_REF=
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=

# ===========================================
# SERVER
# ===========================================
PORT=5000
USER_PORT=3001
ADMIN_PORT=3002
NODE_ENV=development

# ===========================================
# AUTH / SECURITY
# ===========================================
# Generate with: openssl rand -base64 48
SESSION_SECRET=
ADMIN_EMAIL=admin@example.com

# Legacy Replit OIDC (removed when Clerk ships in Week 1)
REPL_ID=
REPLIT_DEV_DOMAIN=
REPLIT_DOMAINS=

# Phase 1 — Clerk (Week 1)
# Founder inject here when ready: Clerk Dashboard API keys + webhook secret.
# Then run `npm run test` and boot auth locally before cutover.
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
CLERK_WEBHOOK_SECRET=
VITE_CLERK_PUBLISHABLE_KEY=

# ===========================================
# PAYMENTS — STRIPE
# ===========================================
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_
STRIPE_PUBLISHABLE_KEY=pk_test_
# Stripe Connect (Week 5)
# Founder inject here when Stripe Connect is enabled.
STRIPE_CONNECT_CLIENT_ID=

# ===========================================
# AI
# ===========================================
ANTHROPIC_API_KEY=sk-ant-
OPENAI_API_KEY=sk-
# Alternate var name the codebase also checks
OPEN_AI_KEY=

OPENMETER_API_KEY=
OPENMETER_BASE_URL=

# ===========================================
# NOTIFICATIONS — ONESIGNAL
# ===========================================
# Founder inject here when OneSignal app/API keys are created.
# This unblocks delivery tests beyond the current smoke invocation checks.
ONESIGNAL_APP_ID=
ONESIGNAL_API_KEY=

# ===========================================
# DATA ENGINE INTEGRATION
# ===========================================
# Inject these to test real dataintakegrit -> gritapp webhook flow.
DATA_ENGINE_API_URL=
DATA_ENGINE_API_KEY=
WEBHOOK_KEY=

# ===========================================
# PHASE 1 — STACK ADDITIONS (Week 1+)
# ===========================================
# Inngest — background jobs (replaces node-cron + pg-boss)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Upstash Redis — leaderboard cache + rate limiting
# Founder inject here when Upstash is created.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Resend — transactional email
# Founder inject here when Resend domain/API key are ready.
RESEND_API_KEY=

# PostHog — analytics + feature flags
# Founder inject here when PostHog is created.
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.posthog.com

# ===========================================
# OBSERVABILITY
# ===========================================
SENTRY_DSN=
LOG_LEVEL=info

# ===========================================
# MISC
# ===========================================
CUSTOM_DOMAIN=

# ===========================================
# OPTIONAL — GOOGLE OAUTH (unused unless wired)
# ===========================================
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# Local, read-only populated UI audit mode. Never enable in production.
UI_AUDIT_FIXTURES=0
