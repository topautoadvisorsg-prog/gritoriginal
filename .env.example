# Environment Variables Example

# ===========================================
# DATABASE CONFIGURATION
# ===========================================
DATABASE_URL=postgresql://user:password@localhost:5432/grit_db
DIRECT_URL=postgresql://user:password@localhost:5432/grit_db

# ===========================================
# SERVER CONFIGURATION
# ===========================================
PORT=5000
USER_PORT=3001
ADMIN_PORT=3002
NODE_ENV=development  # 'development' | 'production' | 'test'

# ===========================================
# AUTHENTICATION & SECURITY
# ===========================================
# SESSION_SECRET=your_secret_here  # Must be at least 32 characters
REPL_ID=  # Replit OIDC (if using)
REPLIT_DEV_DOMAIN=  # Replit development domain
REPLIT_DOMAINS=  # Replit domains

# ===========================================
# EXTERNAL SERVICES - PAYMENTS
# ===========================================
STRIPE_SECRET_KEY=sk_test_...  # Stripe secret key
STRIPE_WEBHOOK_SECRET=whsec_...  # Stripe webhook signing secret

# ===========================================
# EXTERNAL SERVICES - AI/ML
# ===========================================
ANTHROPIC_API_KEY=sk-ant-...  # Claude API key (required for AI Predictor)
OPENAI_API_KEY=sk-...  # OpenAI API key (optional, fallback)
OPENMETER_API_KEY=  # OpenMeter usage tracking API key

# ===========================================
# EXTERNAL SERVICES - NOTIFICATIONS
# ===========================================
ONESIGNAL_APP_ID=  # OneSignal app ID for push notifications
ONESIGNAL_API_KEY=  # OneSignal API key for push notifications

# ===========================================
# EXTERNAL SERVICES - DATA ENGINE INTEGRATION
# ===========================================
DATA_ENGINE_API_URL=https://your-data-engine-api.com  # External data engine API URL
DATA_ENGINE_API_KEY=  # External data engine API authentication key

# ===========================================
# ADMIN CONFIGURATION
# ===========================================
ADMIN_EMAIL=admin@example.com  # Admin user email for role assignment

# ===========================================
# OPTIONAL - GOOGLE OAUTH (if used)
# ===========================================
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

